# ── Keylone — External PostgreSQL configuration ───────────────────────────────
#
# Copy to .env and fill in your values:
#   cp .env.external.example .env
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string to your existing PostgreSQL instance.
# Use host.docker.internal to reach PostgreSQL running on the host machine.
DATABASE_URL=postgresql://keylone:CHANGE_ME@host.docker.internal:5432/keylone

# JWT signing secret — must be a long random string (min 32 chars).
JWT_SECRET=CHANGE_ME

# Your domain name for WebAuthn (passkeys).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Optional: SOCKS5/HTTP proxy for Telegram Bot API.
TELEGRAM_PROXY=
