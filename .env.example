# ── Keylone — configuration ───────────────────────────────────────────────────
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Or run ./setup.sh — it will generate everything automatically.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password — used by both the postgres container and the app.
POSTGRES_PASSWORD=CHANGE_ME

# JWT signing secret — must be a long random string (min 32 chars).
# Generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME

# Your domain name for WebAuthn (passkeys).
# Use "localhost" for local testing, your real domain for production.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Optional: SOCKS5/HTTP proxy for Telegram Bot API.
# Needed only if Telegram is blocked in your region.
# Example: socks5://user:pass@proxy-host:1080
TELEGRAM_PROXY=
